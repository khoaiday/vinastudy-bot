# VInaStudy Pipeline Configuration
# Điền PROD_URL = URL Railway thật của bạn

# Lấy URL từ: Railway Dashboard → Project → Settings → Domain
PROD_URL=https://vinastudy-bot-production.up.railway.app

# Branch Claude Code đang làm việc (mặc định: dev)
WATCH_BRANCH=dev

# Branch deploy lên Railway (mặc định: main)
DEPLOY_BRANCH=main

# Thời gian chờ Railway deploy xong (giây)
DEPLOY_WAIT_SECONDS=90

# Poll git mỗi N giây
POLL_INTERVAL_SECONDS=15
