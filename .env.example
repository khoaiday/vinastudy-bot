# ── Copy file này thành .env rồi điền giá trị thực ──────────────────────────
# cp .env.example .env   (Linux/Mac)
# copy .env.example .env (Windows)

# ── Bắt buộc để chạy web server ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/vinastudy
SECRET_KEY=random-32-char-string-thay-cai-nay

# ── Bot Telegram (không cần nếu chỉ test web) ────────────────────────────────
TELEGRAM_TOKEN=
ADMIN_BOT_TOKEN=

# ── Google OAuth (không cần nếu dùng ?dev=1) ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Tuỳ chọn ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
REPLICATE_API_TOKEN=
ADMIN_ID=0
BASE_DOMAIN=http://localhost:8080
PORT=8080
